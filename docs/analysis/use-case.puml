' PlantUML Use Case Diagram

' For preview in VSCode:
' 1. you need to have Java and Graphviz installed on your system
' 2. install the "PlantUML" extension by jebbs
' 3. right click -> "Preview Current Diagram" or Alt + D

@startuml Study Manager 

!pragma ratio 0.80

left to right direction

' Style: (colors from https://sarafian.github.io/assets/images/posts/plantuml/2021-02-24-plantuml-tips-tricks-1/colors.svg)
skinparam UsecaseBackgroundColor SkyBlue
skinparam RectangleBackgroundColor APPLICATION
skinparam ActorBackgroundColor MidnightBlue
skinparam ActorStyle Hollow

' Actors:
actor "Unregistered User" as unregisteredUser
actor "User" as user
actor "Mentor" as mentor
actor "Admin" as admin
'actor "<<System>>" as system
actor "<<Time>>" as time

' System boundary:
rectangle "Study Manager" as studyManager {
    ' unregistered user
    usecase "Create account" as createAccount
    usecase "Log in" as logIn

    ' logged in user
    usecase "Manage tasks" as manageTask
    usecase "Search task" as searchTask #aquamarine
    usecase "Mark as done" as markDone #aquamarine
    usecase "Filter tasks" as filter
    usecase "Manage events" as manageEvent
    usecase "Manage notes" as manageNotes
    usecase "See my groups" as seeGroups
    usecase "Import calendar" as importCal
    usecase "See calendar" as seeCal
    usecase "Manage profile" as manageProfile
    usecase "Change personal information" as changePersonalInfo #aquamarine
    usecase "Change password" as changePassword #aquamarine
    usecase "Change settings" as settings #aquamarine
    usecase "Set language" as setLanguage #aquamarine
    usecase "Set mode" as setMode #aquamarine
    usecase "Read emails" as readEmails
    usecase "Manage timer" as manageTimer
    usecase "Start timer" as startTimer #aquamarine
    usecase "See timer history" as timerHistory #aquamarine
    usecase "Log out" as logOut

    ' mentor
    usecase "Manage groups" as manageGroup
    usecase "Assign task" as assignTask #aquamarine
    usecase "Search student" as searchStudent #aquamarine
    usecase "Message group" as messageGroup #aquamarine
    usecase "Evaluate student" as evaluateStudent
    usecase "Give feedback" as giveFeedback
    
    'admin or system
    usecase "Send email notification" as sendNotification
    usecase "Check deadlines" as checkDeadlines #aquamarine
    usecase "Manage users" as manageUsers
    usecase "Manage roles" as manageRoles
    usecase "Manage system settings" as manageSystemSettings
    usecase "View system logs" as viewLogs
    usecase "Manage database" as manageDatabase
}

' Generalizations
mentor -[norank]-|> user

' Includes and extends
manageTask ..> searchTask : <<include>>
manageTask ..> markDone : <<include>>
manageProfile ..> changePersonalInfo : <<include>>
manageProfile ..> changePassword : <<include>>
manageProfile ..> settings : <<include>>
settings ..> setLanguage : <<include>>
settings ..> setMode : <<include>>
manageTimer ..> startTimer : <<include>>
manageTimer ..> timerHistory : <<include>>

manageGroup ..> assignTask : <<include>>
manageGroup ..> searchStudent : <<include>>
manageGroup ..> messageGroup : <<include>>

sendNotification ..> checkDeadlines : <<extend>>\nif date > deadline

' Associations:
unregisteredUser --> createAccount
unregisteredUser --> logIn

user --> manageTask
user --> filter
user --> manageEvent
user --> manageNotes
user --> seeGroups
user --> importCal
user --> seeCal
user --> manageProfile
user --> readEmails
user --> manageTimer
user --> logOut
sendNotification --> user

mentor --> manageGroup
mentor --> evaluateStudent
mentor --> giveFeedback

checkDeadlines <-- time
manageUsers <-- admin
manageRoles <-- admin
manageSystemSettings <-- admin
viewLogs <-- admin
manageDatabase <-- admin

' For layout purposes:
filter <-[hidden]- manageUsers
filter <-[hidden]- manageRoles
filter <-[hidden]- manageSystemSettings
filter <-[hidden]- viewLogs
filter <-[hidden]- manageDatabase

@enduml
